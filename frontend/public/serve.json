    { "source": "/products/baby/Baby_Jeep_Rent.html", "destination": "/rent/baby-jeep-rental/chennai", "type": 301 },
    { "source": "/Hyderabad/products/backdrop/Elegant_Greenish_backdrop_rental.html", "destination": "/rent/elegant-greenish-backdrop/hyderabad", "type": 301 }
  ]
