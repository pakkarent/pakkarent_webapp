FROM node:18-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci || npm install

COPY . .

ARG REACT_APP_API_URL
ENV REACT_APP_API_URL=$REACT_APP_API_URL

RUN npm run build


FROM node:18-alpine

WORKDIR /app

RUN npm install -g serve@14

COPY --from=build /app/build ./build

ENV PORT=3000
EXPOSE 3000

CMD ["serve", "-s", "build"]
