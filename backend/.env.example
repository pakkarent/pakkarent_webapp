PORT=5001
CLIENT_URL=http://localhost:3000
# Comma-separated browser origins (custom domain + Render preview URL)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=development

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://rxfgnbshfhbvngmtezhs.supabase.co
SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key
SUPABASE_STORAGE_BUCKET=pakkarent_images

# PostgreSQL connection (Supabase → Settings → Database → Connection string → URI)
# Session pooler (IPv4): aws-1-ap-southeast-2.pooler.supabase.com:5432
DATABASE_URL=postgresql://postgres.rxfgnbshfhbvngmtezhs:[YOUR-DB-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres
DB_SSL=true

# Order inquiry emails (optional — logs to console if unset)
INQUIRY_EMAIL_TO=pakkarent@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
